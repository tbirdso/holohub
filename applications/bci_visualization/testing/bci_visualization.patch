+FRAME_COUNT = 10
+
+
+class BciFilterStartupOp(Operator):
+    """An operator to filter out initial blank frames from test recording validation"""
+    def __init__(self, fragment, *args, **kwargs):
+        super().__init__(fragment, *args, **kwargs)
+        self.nonzero_count = 0
+
+    def setup(self, spec: OperatorSpec):
+        spec.input("in")
+        spec.output("out")
+
+    def compute(self, op_input, op_output, context):
+        import cupy as cp
+
+        input_message = op_input.receive("in")
+
+        # Check if the frame has non-zero content
+        if input_message:
+            # Video buffers use empty string key ""
+            tensor = input_message.get("")
+            if tensor is not None:
+                cp_array = cp.asarray(tensor)
+                if cp.any(cp_array):
+                    self.nonzero_count += 1
+
+        # Only emit after we've seen at least two valid frames
+        if self.nonzero_count >= 2 and input_message:
+            op_output.emit(input_message, "out")
+
+
+
 
