#!/bin/bash

# Display usage information
usage() {
    echo "Usage: holohub <command> [options]"
    echo ""
    echo "Commands:"
    echo "  build-container [<APP|OP|PKG>]        Build the development container with specific Dockerfile"
    echo "  run-container                         Launch the development container"
    echo "  create <APP> [--language cpp|python]  Initialize a new application with templates"
    echo "  build <APP|OP|PKG> [--local]         Build a project"
    echo "  install <APP|OP|PKG> [--local]       Install a project"
    echo "  run <APP> [--local]                  Run an application"
    echo "  lint [--fix] [--install-dependencies] <PATH>  Run linter on specified path"
    echo ""
    echo "Options:"
    echo "  --local                    Execute commands locally instead of in container"
    echo "  --language cpp|python      Specify language for new application (with create)"
    echo "  --fix                      Fix linting issues automatically"
    echo "  --install-dependencies     Install linting dependencies"
    exit 1
}

# Helper function to run prerequisites
run_prerequisites() {
    local command=$1
    case $command in
        "run-container")
            ./dev_container build
            ;;
        "build")
            if [ "$local_flag" != "--local" ]; then
                ./dev_container build
                ./dev_container launch
            fi
            ;;
        "install")
            if [ "$local_flag" != "--local" ]; then
                ./dev_container build
                ./dev_container launch
            fi
            ;;
        "run")
            if [ "$local_flag" != "--local" ]; then
                ./dev_container build
                ./dev_container launch
            fi
            ;;
    esac
}

# Check if at least one argument is provided
if [ $# -lt 1 ]; then
    usage
fi

command=$1
shift # Remove command from args

# Parse flags and arguments
local_flag=""
language=""
fix_flag=""
install_deps_flag=""
project=""
extra_args=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --local)
            local_flag="--local"
            shift
            ;;
        --language)
            language="$2"
            shift 2
            ;;
        --fix)
            fix_flag="--fix"
            shift
            ;;
        --install-dependencies)
            install_deps_flag="--install-dependencies"
            shift
            ;;
        *)
            if [ -z "$project" ]; then
                project="$1"
            else
                extra_args+=("$1")
            fi
            shift
            ;;
    esac
done

case $command in
    "build-container")
        if [ -n "$project" ]; then
            ./dev_container build --dockerfile "/path/to/$project/Dockerfile" "${extra_args[@]}"
        else
            ./dev_container build "${extra_args[@]}"
        fi
        ;;
        
    "run-container")
        run_prerequisites "run-container"
        ./dev_container launch "${extra_args[@]}"
        ;;
        
    "create")
        if [ -z "$project" ]; then
            echo "Error: Application name required"
            usage
        fi
        if [ "$language" != "cpp" ] && [ "$language" != "python" ] && [ -n "$language" ]; then
            echo "Error: Language must be either 'cpp' or 'python'"
            usage
        fi
        # TODO: Implement template initialization logic
        echo "Creating new $language application: $project"
        ;;
        
    "build")
        if [ -z "$project" ]; then
            echo "Error: Project name required"
            usage
        fi
        if [ "$local_flag" == "--local" ]; then
            ./run build "$project" "${extra_args[@]}"
        else
            run_prerequisites "build"
            ./dev_container build_and_run "$project" --no_run "${extra_args[@]}"
        fi
        ;;
        
    "install")
        if [ -z "$project" ]; then
            echo "Error: Project name required"
            usage
        fi
        if [ "$local_flag" == "--local" ]; then
            ./run build "$project" --install "${extra_args[@]}"
        else
            run_prerequisites "install"
            ./dev_container build_and_install "$project" "${extra_args[@]}"
        fi
        ;;
        
    "run")
        if [ -z "$project" ]; then
            echo "Error: Project name required"
            usage
        fi
        if [ "$local_flag" == "--local" ]; then
            ./run launch "$project" "${extra_args[@]}"
        else
            run_prerequisites "run"
            ./dev_container build_and_run "$project" "${extra_args[@]}"
        fi
        ;;
        
    "lint")
        if [ -z "$project" ]; then
            echo "Error: Path required"
            usage
        fi
        
        lint_command="./run lint"
        if [ -n "$fix_flag" ]; then
            lint_command="$lint_command --fix"
        fi
        if [ -n "$install_deps_flag" ]; then
            lint_command="$lint_command --install-dependencies"
        fi
        $lint_command "$project" "${extra_args[@]}"
        ;;
        
    *)
        echo "Error: Unknown command '$command'"
        usage
        ;;
esac 